# Copy to .env and fill in. Nothing here is needed for `python run_demo.py`
# (the drafter falls back to a $0 template when these are absent).

# --- Azure AI Foundry (Microsoft Foundry) — Claude drafting backend ---
# After deploying a Claude model in your Foundry resource (serverless), copy:
AZURE_FOUNDRY_API_KEY=
AZURE_FOUNDRY_RESOURCE=
FOUNDRY_CLAUDE_MODEL=claude-haiku-4-5

# --- Jira (production delivery: comment + @mention). Not needed for the demo. ---
JIRA_BASE_URL=
JIRA_TOKEN=
