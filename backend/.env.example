# Copy this file to `.env` in this backend/ folder and fill in the values.
# Nothing here is needed for `python run_demo.py` — the drafter falls back to a
# $0 template when these are absent. .env is loaded automatically (python-dotenv).
# NOTE: put real secrets in .env (gitignored), NEVER in this tracked template.

# --- Claude via Azure AI Foundry (Microsoft Foundry) — the drafting backend ---
# After deploying a Claude model, open the deployment's "Details" tab and copy:
#   - Key       -> AZURE_FOUNDRY_API_KEY
#   - the <name> in the Target URI https://<name>.services.ai.azure.com/anthropic/...
#                 -> AZURE_FOUNDRY_RESOURCE  (the resource NAME only, NOT a full URL)
AZURE_FOUNDRY_API_KEY=
AZURE_FOUNDRY_RESOURCE=
# Alternative to the resource name — paste the full base URL instead:
# AZURE_FOUNDRY_BASE_URL=https://my-foundry-res.services.ai.azure.com/anthropic
# Your Foundry *deployment name* (defaults to the model id when you deploy):
FOUNDRY_CLAUDE_MODEL=claude-haiku-4-5

# --- OR free alternative: Google Gemini (AI Studio free tier, usually no card) ---
# Get a free key at https://aistudio.google.com/apikey
# The drafter auto-selects: Claude/Foundry if set, else Gemini if set, else the $0 template.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Jira (production delivery: comment + @mention). Not needed for the demo. ---
JIRA_BASE_URL=
JIRA_TOKEN=
